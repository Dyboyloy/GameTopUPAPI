// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  email String @unique
  username String @unique
  profile Profile?
  orders Order[]
  products Product[]
  role Role @default(USER)
  password String
  createdAt DateTime @default(now())
}

model Profile {
  id String @id @default(cuid())
  user User @relation(fields: [userId], references: [id])
  userId String @unique
  displayName String
  avatarUrl String
}

enum Role {
  USER
  ADMIN
}

model Product {
  id String @id @default(cuid())
  name String
  description String
  imageUrl String
  items Item[]
  ogPrice Float?
  resellerPrice Float?
  price Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  userId String
}

model Item {
  id String @id @default(cuid())
  product Product @relation(fields: [productId], references: [id])
  productId String
  name String
  ogPrice Float?
  resellerPrice Float?
  price Float
  quantity Int @default(1)
  itemsInOrder Order[]
  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(cuid())
  user User @relation(fields: [userId], references: [id])
  userId String
  inGameUsername String
  items Item[]
  total Float
  createdAt DateTime @default(now())
}

model Session {
  id String @id @default(cuid())
  sid String @unique
  data String @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("sessions")
}